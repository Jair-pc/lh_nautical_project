# ==============================================
# LH Nautical — .gitignore
# ==============================================

# Camadas geradas pelo pipeline
# Silver: não versionar (intermediário, reproduzível)
data/silver/
*.csv.gz

# Gold: VERSIONADO para que o app Streamlit (deploy Render) funcione sem rodar o pipeline
# Tamanho atual ~280 KB (fato_vendas + dim_clientes + dim_produtos) — vale a pena versionar
# Se crescer, considerar rodar o ETL no buildCommand do Render
!data/gold/
!data/gold/*.parquet

# Bronze e RAW: dados de entrada versionados (necessários para rodar o pipeline)
# data/bronze/ e data/raw/ são incluídos intencionalmente

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Ambientes virtuais
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Variáveis de ambiente (nunca versionar credenciais)
.env
.env.local
*.env

# Outputs temporários
outputs/
temp/
tmp/

# Modelos treinados (versionar com MLflow ou DVC)
models/*.pkl
models/*.joblib
